<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CELL BLOCK Z — Prison Escape</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#16202e;
    --orange:#ff7a1a;
    --orange-d:#e85d00;
    --green:#3ad17a;
    --green-d:#1f9f55;
    --paper:#fff7ec;
    --shadow:0 8px 0 rgba(0,0,0,.18), 0 14px 30px rgba(0,0,0,.28);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%; overflow:hidden; background:#0b1622; font-family:'Fredoka',system-ui,sans-serif;}
  #game{position:fixed; inset:0;}
  canvas{display:block;}

  /* ---------- HUD ---------- */
  #hud{position:fixed; inset:0; pointer-events:none; color:#fff; user-select:none;}
  .panel{
    background:rgba(20,30,46,.62);
    backdrop-filter:blur(6px);
    border:2px solid rgba(255,255,255,.14);
    border-radius:16px;
    box-shadow:0 6px 0 rgba(0,0,0,.18);
  }
  #objective{
    position:absolute; top:18px; left:18px; max-width:min(60vw,420px);
    padding:12px 16px; font-size:17px; font-weight:500; line-height:1.25;
    letter-spacing:.2px;
  }
  #objective .tag{
    display:inline-block; font-size:11px; font-weight:700; letter-spacing:2px;
    color:var(--orange); text-transform:uppercase; margin-bottom:3px; opacity:.95;
  }
  #topright{position:absolute; top:18px; right:18px; display:flex; gap:10px; align-items:stretch;}
  #topright .pill{padding:10px 14px; font-weight:600; font-size:18px; display:flex; align-items:center; gap:8px;}
  #coins .ic{width:18px;height:18px;border-radius:50%;background:linear-gradient(180deg,#ffd451,#f5a800);box-shadow:inset 0 -2px 0 rgba(0,0,0,.2);}
  #timer{font-variant-numeric:tabular-nums; min-width:92px; justify-content:center;}
  #keycard{
    position:absolute; top:18px; right:18px; transform:translateY(64px);
    padding:9px 13px; font-weight:600; font-size:14px; display:flex; gap:8px; align-items:center;
    opacity:.45; transition:opacity .25s, transform .25s;
  }
  #keycard.have{opacity:1; border-color:rgba(58,209,122,.6);}
  #keycard .card{width:22px;height:15px;border-radius:3px;background:#39ffd0;box-shadow:inset 0 -2px 0 rgba(0,0,0,.25);}
  #keycard.have .card{box-shadow:inset 0 -2px 0 rgba(0,0,0,.25),0 0 10px #39ffd0;}

  /* detection meter */
  #detectWrap{
    position:absolute; left:50%; bottom:26px; transform:translateX(-50%);
    width:min(360px,70vw); padding:10px 14px 12px;
  }
  #detectWrap .lab{display:flex; justify-content:space-between; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; margin-bottom:7px; opacity:.85;}
  #detectBarBg{height:14px; border-radius:10px; background:rgba(0,0,0,.4); overflow:hidden; box-shadow:inset 0 2px 4px rgba(0,0,0,.45);}
  #detectBar{height:100%; width:0%; border-radius:10px; background:var(--green); transition:width .08s linear, background .18s;}
  #detectState{font-weight:600;}

  #hint{
    position:absolute; left:50%; bottom:78px; transform:translateX(-50%) translateY(10px);
    padding:9px 16px; font-weight:500; font-size:15px; opacity:0; transition:opacity .2s, transform .2s;
    white-space:nowrap;
  }
  #hint.show{opacity:1; transform:translateX(-50%) translateY(0);}

  #toast{
    position:absolute; left:50%; top:38%; transform:translate(-50%,-50%) scale(.7);
    font-size:64px; font-weight:700; letter-spacing:3px; color:#fff;
    text-shadow:0 4px 0 #b11226, 0 8px 0 #7c0c1a, 0 16px 30px rgba(0,0,0,.5);
    opacity:0; pointer-events:none;
  }
  #toast.pop{animation:toastpop 1.1s ease forwards;}
  @keyframes toastpop{
    0%{opacity:0; transform:translate(-50%,-50%) scale(.6) rotate(-4deg);}
    18%{opacity:1; transform:translate(-50%,-50%) scale(1.08) rotate(2deg);}
    30%{transform:translate(-50%,-50%) scale(1) rotate(0);}
    80%{opacity:1;}
    100%{opacity:0; transform:translate(-50%,-58%) scale(1);}
  }

  /* alarm vignette */
  #vignette{position:fixed; inset:0; pointer-events:none; box-shadow:inset 0 0 200px 40px rgba(220,30,40,0); transition:box-shadow .15s;}
  #flash{position:fixed; inset:0; pointer-events:none; background:#ff2a3a; opacity:0;}
  #flash.go{animation:flashfade .5s ease forwards;}
  @keyframes flashfade{0%{opacity:.55;}100%{opacity:0;}}

  /* ---------- Screens ---------- */
  .screen{
    position:fixed; inset:0; display:flex; align-items:center; justify-content:center;
    background:radial-gradient(120% 120% at 50% 0%, #2a5fb0 0%, #16335f 48%, #0b1c38 100%);
    z-index:30; text-align:center; color:#fff; padding:24px;
  }
  .screen.hidden{display:none;}
  .card-box{
    pointer-events:auto; width:min(560px,92vw); padding:34px 34px 30px;
    background:var(--paper); color:var(--ink); border-radius:26px;
    box-shadow:var(--shadow); border:3px solid #ffffff;
    position:relative;
  }
  .logo{
    font-size:clamp(40px,8vw,64px); font-weight:700; line-height:.92; letter-spacing:1px;
    color:var(--orange);
    text-shadow:0 4px 0 var(--orange-d), 0 5px 0 var(--orange-d), 0 6px 0 var(--orange-d);
  }
  .logo .z{color:var(--ink); text-shadow:0 4px 0 #000, 0 6px 0 #000;}
  .sub{margin-top:6px; font-weight:600; letter-spacing:3px; font-size:13px; text-transform:uppercase; color:#7c5a3a;}
  .blurb{margin:18px auto 6px; max-width:430px; font-size:16px; line-height:1.5; color:#3a3026;}
  .keys{display:grid; grid-template-columns:repeat(2,1fr); gap:8px 14px; margin:18px auto 4px; max-width:430px; text-align:left;}
  .keys .row{display:flex; align-items:center; gap:10px; font-size:14px; font-weight:500;}
  .kbd{
    display:inline-flex; align-items:center; justify-content:center; min-width:30px; height:30px; padding:0 9px;
    background:#fff; border:2px solid #2a2622; border-bottom-width:4px; border-radius:8px;
    font-weight:700; font-size:13px; color:#2a2622;
  }
  .btn{
    pointer-events:auto; margin-top:22px; cursor:pointer; border:none; font-family:inherit;
    font-weight:700; font-size:21px; letter-spacing:1px; color:#fff;
    background:var(--green); padding:15px 40px; border-radius:16px;
    box-shadow:0 6px 0 var(--green-d), 0 10px 18px rgba(0,0,0,.25);
    transition:transform .08s, box-shadow .08s; text-transform:uppercase;
  }
  .btn:hover{transform:translateY(-1px); box-shadow:0 7px 0 var(--green-d),0 12px 20px rgba(0,0,0,.28);}
  .btn:active{transform:translateY(4px); box-shadow:0 2px 0 var(--green-d);}
  .stats{display:flex; gap:14px; justify-content:center; margin:20px auto 4px; flex-wrap:wrap;}
  .stat{background:#fff; border:2px solid #efe3d2; border-radius:14px; padding:12px 20px; min-width:120px;}
  .stat .v{font-size:30px; font-weight:700; color:var(--orange); line-height:1;}
  .stat .l{font-size:11px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:#8a7a66; margin-top:6px;}
  .smallnote{margin-top:14px; font-size:12px; color:#9a8a76; font-weight:500;}

  #pause .card-box{background:rgba(255,247,236,.97);}
  @media (max-width:520px){ .keys{grid-template-columns:1fr;} }
</style>
</head>
<body>
<div id="game"></div>

<!-- HUD -->
<div id="hud">
  <div id="objective" class="panel"><span class="tag">Objective</span><div id="objText">Escape your cell and find the keycard.</div></div>
  <div id="topright">
    <div id="timer" class="pill panel">00:00</div>
    <div id="coins" class="pill panel"><span class="ic"></span><span id="coinText">0</span></div>
  </div>
  <div id="keycard" class="panel"><span class="card"></span><span>Keycard</span></div>

  <div id="hint" class="panel"></div>

  <div id="detectWrap" class="panel">
    <div class="lab"><span>Detection</span><span id="detectState">Clear</span></div>
    <div id="detectBarBg"><div id="detectBar"></div></div>
  </div>

  <div id="toast"></div>
</div>
<div id="vignette"></div>
<div id="flash"></div>

<!-- Title -->
<div id="title" class="screen">
  <div class="card-box">
    <div class="logo">CELL BLOCK <span class="z">Z</span></div>
    <div class="sub">Prison Escape</div>
    <p class="blurb">You're locked up. Slip past the guards, grab the keycard, and break for the glowing gate. Stay out of the searchlights or it's back to your cell.</p>
    <div class="keys">
      <div class="row"><span class="kbd">W</span><span class="kbd">A</span><span class="kbd">S</span><span class="kbd">D</span> Move</div>
      <div class="row"><span class="kbd">Mouse</span> Look around</div>
      <div class="row"><span class="kbd">Shift</span> Crouch &amp; sneak</div>
      <div class="row"><span class="kbd">Space</span> Jump</div>
    </div>
    <button class="btn" id="playBtn">Play</button>
    <div class="smallnote">Tip: crouching shrinks the range guards can spot you. Use cover to break their line of sight.</div>
  </div>
</div>

<!-- Pause -->
<div id="pause" class="screen hidden">
  <div class="card-box">
    <div class="logo" style="font-size:clamp(32px,6vw,46px)">PAUSED</div>
    <p class="blurb">Click below to dive back in.</p>
    <button class="btn" id="resumeBtn">Resume</button>
  </div>
</div>

<!-- Win -->
<div id="win" class="screen hidden">
  <div class="card-box">
    <div class="logo" style="color:var(--green);text-shadow:0 4px 0 var(--green-d),0 6px 0 var(--green-d)">YOU'RE OUT!</div>
    <div class="sub" style="color:#3c7a52">Freedom</div>
    <div class="stats">
      <div class="stat"><div class="v" id="wTime">--</div><div class="l">Escape Time</div></div>
      <div class="stat"><div class="v" id="wCoins">0</div><div class="l">Contraband</div></div>
      <div class="stat"><div class="v" id="wCaught">0</div><div class="l">Times Caught</div></div>
    </div>
    <button class="btn" id="againBtn">Escape Again</button>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
(function(){
"use strict";

/* ============================================================
   SETUP
============================================================ */
const container = document.getElementById('game');
const scene = new THREE.Scene();
scene.fog = new THREE.Fog(0xbfe0ff, 80, 230);

const camera = new THREE.PerspectiveCamera(62, innerWidth/innerHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ antialias:false, powerPreference:'high-performance' });
renderer.setSize(innerWidth, innerHeight);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFShadowMap;             // pixel ratio + shadow res are driven by the adaptive controller below
renderer.outputEncoding = THREE.sRGBEncoding;
container.appendChild(renderer.domElement);

// Lights
const hemi = new THREE.HemisphereLight(0xeaf4ff, 0x6f7a55, 0.85);
scene.add(hemi);
const sun = new THREE.DirectionalLight(0xfff4e0, 1.05);
sun.position.set(48, 90, -10);
sun.castShadow = true;
sun.shadow.mapSize.set(2048, 2048);   // initial; adaptive controller retunes this live
const sc = 70;
sun.shadow.camera.left = -sc; sun.shadow.camera.right = sc;
sun.shadow.camera.top = sc;  sun.shadow.camera.bottom = -sc;
sun.shadow.camera.near = 1;  sun.shadow.camera.far = 260;
sun.shadow.bias = -0.0004;
scene.add(sun);
const sunTarget = new THREE.Object3D();
sunTarget.position.set(0, 0, 18);
scene.add(sunTarget);
sun.target = sunTarget;

// Sky dome (vertical gradient)
(function(){
  const c = document.createElement('canvas'); c.width = 8; c.height = 256;
  const g = c.getContext('2d');
  const grd = g.createLinearGradient(0,0,0,256);
  grd.addColorStop(0,  '#1f63cf');
  grd.addColorStop(0.5,'#5fa0ee');
  grd.addColorStop(1,  '#cfe9ff');
  g.fillStyle = grd; g.fillRect(0,0,8,256);
  const tex = new THREE.CanvasTexture(c);
  const dome = new THREE.Mesh(
    new THREE.SphereGeometry(400, 24, 16),
    new THREE.MeshBasicMaterial({ map:tex, side:THREE.BackSide, fog:false })
  );
  scene.add(dome);
})();

/* ============================================================
   MATERIALS / HELPERS
============================================================ */
const colliders = [];   // {minX,maxX,minZ,maxZ, ref}
const losBlockers = []; // Mesh[] that block guard vision & camera

function mat(color, opts){
  opts = opts || {};
  return new THREE.MeshLambertMaterial({ color, emissive: opts.emissive||0x000000, emissiveIntensity: opts.ei!=null?opts.ei:1 });
}
function addBox(x,y,z,w,h,d,color,opts){
  opts = opts || {};
  const m = new THREE.Mesh(new THREE.BoxGeometry(w,h,d), mat(color, opts));
  m.position.set(x,y,z);
  m.castShadow = opts.cast!==false;
  m.receiveShadow = opts.receive!==false;
  scene.add(m);
  if(opts.solid){
    colliders.push({ minX:x-w/2, maxX:x+w/2, minZ:z-d/2, maxZ:z+d/2, ref:m });
    m.userData.collider = colliders[colliders.length-1];
  }
  if(opts.blockLOS) losBlockers.push(m);
  return m;
}

/* ============================================================
   WORLD
============================================================ */
// big base ground (so the world continues past the exit)
(function(){
  const g = new THREE.Mesh(new THREE.PlaneGeometry(420, 520), mat(0x4ea84e));
  g.rotation.x = -Math.PI/2; g.position.set(0,-0.02,40); g.receiveShadow = true;
  scene.add(g);
})();

// checker yard floor texture
function checkerTex(a,b,n){
  const c=document.createElement('canvas'); c.width=c.height=256; const g=c.getContext('2d');
  const s=256/n;
  for(let i=0;i<n;i++)for(let j=0;j<n;j++){ g.fillStyle=((i+j)%2)?a:b; g.fillRect(i*s,j*s,s,s); }
  const t=new THREE.CanvasTexture(c); t.wrapS=t.wrapT=THREE.RepeatWrapping; t.magFilter=THREE.NearestFilter; return t;
}

// Yard floor (grass checker)
(function(){
  const tex = checkerTex('#57b257','#4aa14a',2);
  tex.repeat.set(15, 15);
  const m = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), new THREE.MeshLambertMaterial({ map:tex }));
  m.rotation.x=-Math.PI/2; m.position.set(0,0,22); m.receiveShadow=true; scene.add(m);
})();

// Cell block floor (concrete)
addBox(0,-0.04,-26, 32, 0.1, 36, 0x6e7682, {solid:false, cast:false});

const WALL = 0x9aa3ad, TRIM = 0xc94d3a, CONCRETE_D = 0x7d8794;
const WH = 9; // wall height

// --- Cell block walls (open top) ---
addBox(0, WH/2, -44, 32, WH, 1, WALL, {solid:true, blockLOS:true});                 // north
addBox(-16, WH/2, -26, 1, WH, 36, WALL, {solid:true, blockLOS:true});               // west
addBox(16, WH/2, -26, 1, WH, 36, WALL, {solid:true, blockLOS:true});                // east
addBox(-9.5, WH/2, -8, 13, WH, 1, WALL, {solid:true, blockLOS:true});               // south-left (gap x[-3,3])
addBox(9.5, WH/2, -8, 13, WH, 1, WALL, {solid:true, blockLOS:true});                // south-right
// red trim line along north wall top
addBox(0, WH-0.6, -43.55, 32, 0.5, 0.4, TRIM, {cast:false});

// cell-block decor: bunk beds (visual cover, no collision to keep spawn clean)
function bunk(x,z){
  addBox(x, 0.5, z, 2.6, 0.3, 1.3, 0x4f5663, {});         // lower frame
  addBox(x, 0.7, z, 2.4, 0.18, 1.1, 0xd9d2c4, {});         // lower mattress
  addBox(x, 1.7, z, 2.6, 0.3, 1.3, 0x4f5663, {});         // upper frame
  addBox(x, 1.9, z, 2.4, 0.18, 1.1, 0xd9d2c4, {});         // upper mattress
  addBox(x-1.2, 1.0, z, 0.16, 2.0, 1.3, 0x3c424d, {});     // posts
  addBox(x+1.2, 1.0, z, 0.16, 2.0, 1.3, 0x3c424d, {});
}
bunk(-12.5, -41); bunk(12.5, -41);

// cell "bars" near spawn (decoration)
for(let i=0;i<6;i++){ addBox(-7 + i*0.6, 2.4, -37.5, 0.12, 4.6, 0.12, 0x2a2f38, {cast:false}); }
addBox(-4.0, 4.85, -37.5, 4.0, 0.25, 0.25, 0x2a2f38, {cast:false});

// --- Yard outer walls (open top) ---
const YH = 11;
addBox(-30, YH/2, 22, 1, YH, 60, WALL, {solid:true, blockLOS:true});                // west
addBox(30, YH/2, 22, 1, YH, 60, WALL, {solid:true, blockLOS:true});                 // east
addBox(-17, YH/2, 52, 26, YH, 1, WALL, {solid:true, blockLOS:true});                // south-left  (exit gap x[-4,4])
addBox(17, YH/2, 52, 26, YH, 1, WALL, {solid:true, blockLOS:true});                 // south-right
// connect yard north corners to cell block (cell block only spans x[-16,16])
addBox(-23, YH/2, -8, 14, YH, 1, WALL, {solid:true, blockLOS:true});
addBox(23, YH/2, -8, 14, YH, 1, WALL, {solid:true, blockLOS:true});
// barbed-wire-ish red trim along yard tops
[[-30,22,60,'z'],[30,22,60,'z'],[-17,52,26,'x'],[17,52,26,'x']].forEach(([x,z,len,ax])=>{
  if(ax==='z') addBox(x, YH-0.5, z, 0.4, 0.4, len, TRIM, {cast:false});
  else addBox(x, YH-0.5, z, len, 0.4, 0.4, TRIM, {cast:false});
});

// Guard towers (decorative, sit on wall corners)
function tower(x,z){
  addBox(x, 3, z, 2.2, 6, 2.2, 0x6b7480, {});
  addBox(x, 6.4, z, 3.4, 1.1, 3.4, 0x515a66, {});
  addBox(x, 7.3, z, 3.0, 0.7, 3.0, 0xc94d3a, {cast:false}); // roof
  addBox(x, 7.9, z, 0.4, 0.6, 0.4, 0x2a2f38, {cast:false});
}
tower(-30,-8); tower(30,-8); tower(-30,52); tower(30,52);

// Cover crates in the yard (block LOS, create stealth routes)
const CRATE = 0xb07a3c;
function crate(x,z,s){ addBox(x, (s||2.6)/2, z, s||2.6, s||2.6, s||2.6, CRATE, {solid:true, blockLOS:true}); 
  addBox(x, (s||2.6)/2, z, (s||2.6)+0.06,(s||2.6)*0.34,(s||2.6)+0.06,0x8a5e2b,{cast:false}); }
crate(-9, 22); crate(8, 28); crate(-12, 36); crate(11, 17); crate(0, 11, 2.2);

// --- Yard door (locked until keycard) ---
const door = (function(){
  const m = addBox(0, 3.5, -8, 6, 7, 0.7, 0xb43b2c, {solid:true, blockLOS:true, emissive:0x3a0d06, ei:0.4});
  // little window slats
  addBox(0, 5.0, -7.6, 3.2, 0.3, 0.1, 0x2a2f38, {cast:false});
  addBox(0, 4.4, -7.6, 3.2, 0.3, 0.1, 0x2a2f38, {cast:false});
  return { mesh:m, collider:m.userData.collider, open:false, closedY:3.5, t:0 };
})();
function closeDoor(){
  door.open=false; door.t=0; door.mesh.position.y=door.closedY;
  if(colliders.indexOf(door.collider)===-1) colliders.push(door.collider);
}
function openDoor(){
  if(door.open) return;
  door.open=true;
  const i=colliders.indexOf(door.collider); if(i>=0) colliders.splice(i,1);
  sfx('door');
}

// --- Exit gate (glow) at z=52 gap ---
(function(){
  addBox(-4.2, 4, 52, 0.9, 8, 1.4, 0x39ff88, {emissive:0x14c258, ei:1.2});
  addBox(4.2, 4, 52, 0.9, 8, 1.4, 0x39ff88, {emissive:0x14c258, ei:1.2});
  addBox(0, 8.4, 52, 9.5, 1.2, 1.4, 0x39ff88, {emissive:0x14c258, ei:1.2});
  // glowing floor pad
  const pad = new THREE.Mesh(new THREE.PlaneGeometry(7.5, 4), new THREE.MeshBasicMaterial({ color:0x39ff88, transparent:true, opacity:0.55 }));
  pad.rotation.x=-Math.PI/2; pad.position.set(0,0.05,51); scene.add(pad);
  // beam
  const beam = new THREE.Mesh(new THREE.CylinderGeometry(2.6,2.6,18,20,1,true), new THREE.MeshBasicMaterial({ color:0x39ff88, transparent:true, opacity:0.12, side:THREE.DoubleSide, depthWrite:false }));
  beam.position.set(0,9,52); scene.add(beam);
})();
const EXIT = new THREE.Vector3(0,0,52);

/* ============================================================
   CHARACTERS (blocky, Roblox-style)
============================================================ */
function limb(w,h,d,color,jointY){
  const grp = new THREE.Group();
  grp.position.y = jointY;
  const m = new THREE.Mesh(new THREE.BoxGeometry(w,h,d), mat(color));
  m.position.y = -h/2; m.castShadow=true; m.receiveShadow=true;
  grp.add(m);
  return grp;
}
function makeCharacter(c){
  const g = new THREE.Group();
  // legs
  const ll = limb(0.34,0.95,0.34, c.legs, 0.95);
  const rl = limb(0.34,0.95,0.34, c.legs, 0.95);
  ll.position.x = -0.23; rl.position.x = 0.23;
  // torso
  const torso = new THREE.Mesh(new THREE.BoxGeometry(0.92,0.95,0.5), mat(c.torso));
  torso.position.y = 1.42; torso.castShadow=true; torso.receiveShadow=true;
  // badge / collar accent
  const collar = new THREE.Mesh(new THREE.BoxGeometry(0.94,0.18,0.52), mat(c.collar||c.torso));
  collar.position.y = 1.84;
  // arms
  const la = limb(0.3,0.92,0.3, c.arms, 1.84);
  const ra = limb(0.3,0.92,0.3, c.arms, 1.84);
  la.position.x = -0.62; ra.position.x = 0.62;
  // head
  const head = new THREE.Mesh(new THREE.BoxGeometry(0.6,0.6,0.6), mat(c.skin));
  head.position.y = 2.18; head.castShadow=true;
  g.add(ll, rl, torso, collar, la, ra, head);
  if(c.cap){
    const cap = new THREE.Mesh(new THREE.BoxGeometry(0.66,0.22,0.66), mat(c.cap));
    cap.position.y = 2.55; g.add(cap);
    const brim = new THREE.Mesh(new THREE.BoxGeometry(0.66,0.1,0.3), mat(c.cap));
    brim.position.set(0,2.46,0.42); g.add(brim);
  } else {
    const hair = new THREE.Mesh(new THREE.BoxGeometry(0.64,0.18,0.64), mat(c.hair||0x4a3526));
    hair.position.y = 2.5; g.add(hair);
  }
  return { group:g, parts:{ll,rl,la,ra}, phase:0 };
}
function animChar(ch, speed, dt){
  const target = Math.min(speed/6, 1) * 0.7;
  ch.phase += dt * (4 + speed*1.1);
  const sw = Math.sin(ch.phase) * (speed>0.2 ? target : 0);
  // ease toward 0 when idle
  const k = 1 - Math.pow(0.0005, dt);
  ch.parts.ll.rotation.x += ((speed>0.2? sw:0) - ch.parts.ll.rotation.x)*k;
  ch.parts.rl.rotation.x += ((speed>0.2?-sw:0) - ch.parts.rl.rotation.x)*k;
  ch.parts.la.rotation.x += ((speed>0.2?-sw:0) - ch.parts.la.rotation.x)*k;
  ch.parts.ra.rotation.x += ((speed>0.2? sw:0) - ch.parts.ra.rotation.x)*k;
}

// Player
const SPAWN = new THREE.Vector3(-11, 0, -39);
const playerChar = makeCharacter({ legs:0x2b3340, torso:0xff7a1a, collar:0xff9747, arms:0xff7a1a, skin:0xf0c39a, hair:0x4a3526 });
scene.add(playerChar.group);
const player = { pos: SPAWN.clone(), vy:0, grounded:true, crouch:false, radius:0.55, speed:0 };
playerChar.group.position.copy(player.pos);

/* ============================================================
   VISION WEDGE
============================================================ */
function visionWedge(radius, half, segs, color){
  const verts=[];
  for(let i=0;i<segs;i++){
    const a0=-half+(i/segs)*2*half, a1=-half+((i+1)/segs)*2*half;
    verts.push(0,0,0, Math.sin(a0)*radius,0,Math.cos(a0)*radius, Math.sin(a1)*radius,0,Math.cos(a1)*radius);
  }
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.Float32BufferAttribute(verts,3));
  const m=new THREE.Mesh(geo, new THREE.MeshBasicMaterial({ color, transparent:true, opacity:0.16, side:THREE.DoubleSide, depthWrite:false }));
  m.position.y=0.07; m.renderOrder=2;
  return m;
}

/* ============================================================
   GUARDS
============================================================ */
const guards = [];
function makeGuard(waypoints, speed, viewDist, half){
  const ch = makeCharacter({ legs:0x232c47, torso:0x2b3a67, collar:0x1d2a4d, arms:0x2b3a67, skin:0xe7b58c, cap:0x1d2a4d });
  scene.add(ch.group);
  const wedge = visionWedge(viewDist, half, 18, 0xffe14d);
  ch.group.add(wedge);
  const g = {
    char:ch, group:ch.group, wedge,
    waypoints: waypoints.map(p=>new THREE.Vector3(p[0],0,p[1])),
    start: new THREE.Vector3(waypoints[0][0],0,waypoints[0][1]),
    wi:0, speed, viewDist, half, alert:0
  };
  g.group.position.copy(g.start);
  guards.push(g);
  return g;
}
// indoor patrol
makeGuard([[0,-13],[0,-39]], 3.0, 12, 0.62);
// yard patrols (overlapping coverage of the center lane to the exit)
makeGuard([[-18,4],[-18,46],[-2,46],[-2,4]], 3.6, 14, 0.6);
makeGuard([[18,8],[18,44],[6,44],[6,8]], 3.6, 14, 0.6);

function lerpAngle(a,b,t){
  let d=((b-a+Math.PI)%(Math.PI*2))-Math.PI; if(d<-Math.PI)d+=Math.PI*2;
  return a + d*t;
}
function updateGuard(g, dt){
  if(g.alert>0){
    const dx=player.pos.x-g.group.position.x, dz=player.pos.z-g.group.position.z;
    g.group.rotation.y = lerpAngle(g.group.rotation.y, Math.atan2(dx,dz), 1-Math.pow(0.0001,dt));
    g.alert -= dt;
    animChar(g.char, 0, dt);
  } else {
    const wp=g.waypoints[g.wi];
    const dx=wp.x-g.group.position.x, dz=wp.z-g.group.position.z;
    const dist=Math.hypot(dx,dz);
    if(dist<0.4){ g.wi=(g.wi+1)%g.waypoints.length; animChar(g.char,0,dt); }
    else{
      const vx=dx/dist, vz=dz/dist;
      g.group.position.x += vx*g.speed*dt;
      g.group.position.z += vz*g.speed*dt;
      g.group.rotation.y = lerpAngle(g.group.rotation.y, Math.atan2(dx,dz), 1-Math.pow(0.00005,dt));
      animChar(g.char, g.speed, dt);
    }
  }
}

const raycaster = new THREE.Raycaster();
const _ro = new THREE.Vector3(), _rd = new THREE.Vector3();
function guardSees(g){
  const gx=g.group.position.x, gz=g.group.position.z;
  const dx=player.pos.x-gx, dz=player.pos.z-gz;
  const dist=Math.hypot(dx,dz);
  let vd=g.viewDist; if(player.crouch) vd*=0.55;
  if(dist>vd || dist<0.05) return false;
  const yaw=g.group.rotation.y;
  const dot=(Math.sin(yaw)*dx + Math.cos(yaw)*dz)/dist;
  if(dot < Math.cos(g.half)) return false;
  _ro.set(gx, 1.5, gz);
  _rd.set(dx, (player.pos.y+1.0)-1.5, dz).normalize();
  raycaster.set(_ro, _rd);
  raycaster.far = Math.max(0.1, dist-0.4);
  if(raycaster.intersectObjects(losBlockers, false).length>0) return false;
  return true;
}

/* ============================================================
   COLLECTIBLES
============================================================ */
// Keycard
const keycard = (function(){
  const grp = new THREE.Group();
  const card = new THREE.Mesh(new THREE.BoxGeometry(0.7,0.45,0.06), mat(0x39ffd0,{emissive:0x12b89a, ei:1.3}));
  const stripe = new THREE.Mesh(new THREE.BoxGeometry(0.7,0.1,0.07), mat(0x0a3b33));
  stripe.position.y=0.08;
  grp.add(card, stripe);
  grp.position.set(13.5, 1.4, -11.5); // SE corner, past the indoor guard
  scene.add(grp);
  // glow ring on floor
  const ring=new THREE.Mesh(new THREE.RingGeometry(0.8,1.15,24), new THREE.MeshBasicMaterial({color:0x39ffd0,transparent:true,opacity:0.4,side:THREE.DoubleSide}));
  ring.rotation.x=-Math.PI/2; ring.position.set(13.5,0.06,-11.5); scene.add(ring);
  return { group:grp, ring, collected:false, baseY:1.4 };
})();

// Coins
const coins = [];
function addCoin(x,z){
  const grp=new THREE.Group();
  const c=new THREE.Mesh(new THREE.CylinderGeometry(0.4,0.4,0.1,18), mat(0xffd451,{emissive:0x6b4d00, ei:0.6}));
  c.rotation.x=Math.PI/2; c.castShadow=true;
  const inner=new THREE.Mesh(new THREE.CylinderGeometry(0.26,0.26,0.12,18), mat(0xffe898));
  inner.rotation.x=Math.PI/2;
  grp.add(c, inner);
  grp.position.set(x,1.0,z); scene.add(grp);
  coins.push({ group:grp, collected:false, baseY:1.0, anim:0 });
}
[[8,-30],[-8,-20],[-14,12],[14,12],[0,30],[-12,40],[12,40],[0,48]].forEach(p=>addCoin(p[0],p[1]));

/* ============================================================
   SOUND (tiny WebAudio synth, no files)
============================================================ */
let actx=null;
function initAudio(){ if(!actx){ try{ actx=new (window.AudioContext||window.webkitAudioContext)(); }catch(e){} } }
function tone(freq, dur, type, vol, slideTo){
  if(!actx) return;
  const o=actx.createOscillator(), g=actx.createGain();
  o.type=type||'sine'; o.frequency.value=freq;
  if(slideTo) o.frequency.exponentialRampToValueAtTime(slideTo, actx.currentTime+dur);
  g.gain.value=0.0001;
  g.gain.exponentialRampToValueAtTime(vol||0.2, actx.currentTime+0.01);
  g.gain.exponentialRampToValueAtTime(0.0001, actx.currentTime+dur);
  o.connect(g).connect(actx.destination);
  o.start(); o.stop(actx.currentTime+dur+0.02);
}
function sfx(name){
  if(!actx) return;
  if(name==='coin'){ tone(880,0.08,'square',0.18); setTimeout(()=>tone(1320,0.12,'square',0.16),60); }
  else if(name==='key'){ tone(523,0.1,'triangle',0.2); setTimeout(()=>tone(784,0.1,'triangle',0.2),90); setTimeout(()=>tone(1046,0.18,'triangle',0.2),180); }
  else if(name==='door'){ tone(160,0.3,'sawtooth',0.18,90); }
  else if(name==='alarm'){ tone(740,0.18,'sawtooth',0.22,520); setTimeout(()=>tone(740,0.18,'sawtooth',0.22,520),200); setTimeout(()=>tone(740,0.25,'sawtooth',0.22,520),400); }
  else if(name==='jump'){ tone(300,0.1,'sine',0.12,520); }
  else if(name==='win'){ [523,659,784,1046,1318].forEach((f,i)=>setTimeout(()=>tone(f,0.22,'triangle',0.2),i*110)); }
}

/* ============================================================
   CAMERA CONTROL
============================================================ */
let camYaw = 0, camPitch = 0.55;
const camDist = 7.5;
let pointerLocked = false;
const SENS = 0.0024;

const canvas = renderer.domElement;
function requestLock(){ canvas.requestPointerLock && canvas.requestPointerLock(); }
document.addEventListener('pointerlockchange', ()=>{
  pointerLocked = (document.pointerLockElement === canvas);
  if(!pointerLocked && state==='playing'){ setState('paused'); }
  else if(pointerLocked && state==='paused'){ setState('playing'); }
});
document.addEventListener('mousemove', (e)=>{
  if(!pointerLocked) return;
  camYaw -= e.movementX * SENS;
  camPitch -= e.movementY * SENS;
  camPitch = Math.max(-0.15, Math.min(1.15, camPitch));
});

/* ============================================================
   INPUT
============================================================ */
const keys = {};
addEventListener('keydown', e=>{
  const k=e.key.toLowerCase();
  keys[k]=true;
  if(k===' ') e.preventDefault();
});
addEventListener('keyup', e=>{ keys[e.key.toLowerCase()]=false; });

/* ============================================================
   PLAYER PHYSICS + COLLISION
============================================================ */
function resolveCollisions(){
  for(const c of colliders){
    const cx=Math.max(c.minX, Math.min(player.pos.x, c.maxX));
    const cz=Math.max(c.minZ, Math.min(player.pos.z, c.maxZ));
    let dx=player.pos.x-cx, dz=player.pos.z-cz;
    const d2=dx*dx+dz*dz;
    if(d2 < player.radius*player.radius){
      let d=Math.sqrt(d2);
      if(d<0.0001){
        // center inside box: push along smallest penetration axis
        const penX=Math.min(player.pos.x-c.minX, c.maxX-player.pos.x);
        const penZ=Math.min(player.pos.z-c.minZ, c.maxZ-player.pos.z);
        if(penX<penZ){ player.pos.x += (player.pos.x < (c.minX+c.maxX)/2 ? -1:1)*(penX+player.radius); }
        else{ player.pos.z += (player.pos.z < (c.minZ+c.maxZ)/2 ? -1:1)*(penZ+player.radius); }
      } else {
        const push=(player.radius-d)/d;
        player.pos.x += dx*push; player.pos.z += dz*push;
      }
    }
  }
}

function updatePlayer(dt){
  // movement dir relative to camera
  const sinY=Math.sin(camYaw), cosY=Math.cos(camYaw);
  let fx=-sinY, fz=-cosY;     // forward (W)
  let rx=cosY,  rz=-sinY;     // right (D)
  let mx=0, mz=0;
  if(keys['w']) { mx+=fx; mz+=fz; }
  if(keys['s']) { mx-=fx; mz-=fz; }
  if(keys['d']) { mx+=rx; mz+=rz; }
  if(keys['a']) { mx-=rx; mz-=rz; }
  const len=Math.hypot(mx,mz);
  player.crouch = !!(keys['shift']);
  const moveSpeed = player.crouch ? 3.0 : 6.4;
  let desX=0, desZ=0;
  if(len>0){ mx/=len; mz/=len; desX=mx*moveSpeed; desZ=mz*moveSpeed; }
  player.pos.x += desX*dt;
  player.pos.z += desZ*dt;
  player.speed = Math.hypot(desX,desZ);

  // jump / gravity
  if(keys[' '] && player.grounded){ player.vy=8.2; player.grounded=false; sfx('jump'); }
  player.vy -= 22*dt;
  player.pos.y += player.vy*dt;
  if(player.pos.y<=0){ player.pos.y=0; player.vy=0; player.grounded=true; }

  resolveCollisions();

  // model
  playerChar.group.position.set(player.pos.x, player.pos.y, player.pos.z);
  if(len>0){
    const tYaw=Math.atan2(mx,mz);
    playerChar.group.rotation.y = lerpAngle(playerChar.group.rotation.y, tYaw, 1-Math.pow(0.0006,dt));
  }
  // crouch squash
  const cs = player.crouch ? 0.62 : 1.0;
  playerChar.group.scale.y += (cs - playerChar.group.scale.y)*(1-Math.pow(0.001,dt));
  animChar(playerChar, player.speed, dt);
}

function updateCamera(dt){
  const tx=player.pos.x, ty=player.pos.y + (player.crouch?1.0:1.4), tz=player.pos.z;
  const cp=Math.cos(camPitch), sp=Math.sin(camPitch);
  let ox=Math.sin(camYaw)*cp*camDist;
  let oy=sp*camDist;
  let oz=Math.cos(camYaw)*cp*camDist;
  let cx=tx+ox, cy=ty+oy, cz=tz+oz;
  // camera collision: keep it from going through walls
  _ro.set(tx,ty,tz);
  _rd.set(ox,oy,oz).normalize();
  raycaster.set(_ro,_rd); raycaster.far=camDist;
  const hit=raycaster.intersectObjects(losBlockers,false);
  if(hit.length>0 && hit[0].distance < camDist){
    const d=hit[0].distance-0.4;
    cx=tx+_rd.x*d; cy=ty+_rd.y*d; cz=tz+_rd.z*d;
  }
  cy=Math.max(cy,0.6);
  camera.position.lerp(new THREE.Vector3(cx,cy,cz), 1-Math.pow(0.0001,dt));
  camera.lookAt(tx,ty,tz);
}

/* ============================================================
   GAME STATE / DETECTION / OBJECTIVES
============================================================ */
let state='title';
let detection=0, invuln=0, elapsed=0, coinCount=0, caughtCount=0, hasKey=false;

const el = {
  objText:document.getElementById('objText'),
  coinText:document.getElementById('coinText'),
  timer:document.getElementById('timer'),
  keycard:document.getElementById('keycard'),
  bar:document.getElementById('detectBar'),
  dstate:document.getElementById('detectState'),
  hint:document.getElementById('hint'),
  toast:document.getElementById('toast'),
  vignette:document.getElementById('vignette'),
  flash:document.getElementById('flash'),
};

function setObjective(t){ el.objText.textContent=t; }
function showHint(t){ el.hint.textContent=t; el.hint.classList.add('show'); }
function hideHint(){ el.hint.classList.remove('show'); }

let hintTimer=0;
function flashToast(t){
  el.toast.textContent=t; el.toast.classList.remove('pop'); void el.toast.offsetWidth; el.toast.classList.add('pop');
}

function getCaught(){
  caughtCount++; detection=0; invuln=1.3;
  player.pos.copy(SPAWN); player.vy=0;
  guards.forEach(g=>g.alert=0);
  sfx('alarm');
  el.flash.classList.remove('go'); void el.flash.offsetWidth; el.flash.classList.add('go');
  flashToast('CAUGHT!');
}

function updateDetection(dt){
  if(invuln>0){ invuln-=dt; }
  let seen=false, nearest=Infinity;
  for(const g of guards){
    const s = (invuln<=0) && guardSees(g);
    if(s){
      seen=true; g.alert=2.0;
      const d=Math.hypot(player.pos.x-g.group.position.x, player.pos.z-g.group.position.z);
      nearest=Math.min(nearest,d);
    }
    // wedge color/opacity by alert
    const m=g.wedge.material;
    if(g.alert>0){ m.color.setHex(0xff3b3b); m.opacity=0.26+0.12*Math.sin(now*0.012); }
    else{ m.color.setHex(0xffe14d); m.opacity=0.15; }
  }
  if(seen){
    const closeness = 1 - Math.min(nearest/14, 1);
    const rate = (player.crouch?16:30) * (0.55 + 0.65*closeness);
    detection += rate*dt;
  } else {
    detection -= 28*dt;
  }
  detection=Math.max(0, Math.min(100, detection));
  if(detection>=100) getCaught();

  // HUD meter
  el.bar.style.width = detection.toFixed(1)+'%';
  let col='#3ad17a', label='Clear';
  if(detection>=75){ col='#ff3b3b'; label='SPOTTED!'; }
  else if(detection>=40){ col='#ffb020'; label='Hunting…'; }
  else if(detection>5){ col='#ffe14d'; label='Suspicious'; }
  el.bar.style.background=col; el.dstate.textContent=label;
  const vig = detection>60 ? (detection-60)/40 : 0;
  el.vignette.style.boxShadow = `inset 0 0 200px 40px rgba(220,30,40,${(vig*0.7).toFixed(2)})`;
}

// pickups + door + win checks
function updateInteractions(dt){
  // keycard
  if(!keycard.collected){
    keycard.group.rotation.y += dt*2;
    keycard.group.position.y = keycard.baseY + Math.sin(now*0.004)*0.12;
    if(player.pos.distanceTo(new THREE.Vector3(keycard.group.position.x,player.pos.y,keycard.group.position.z))<1.6){
      keycard.collected=true; hasKey=true;
      keycard.group.visible=false; keycard.ring.visible=false;
      el.keycard.classList.add('have');
      sfx('key'); flashToast('KEYCARD!');
      setObjective('Use the keycard on the red yard door (north of the cells).');
    }
  }
  // coins
  for(const c of coins){
    if(c.collected){
      if(c.anim<1){ c.anim+=dt*3.5; c.group.position.y=c.baseY+c.anim*1.6; c.group.scale.setScalar(Math.max(0,1-c.anim)); if(c.anim>=1)c.group.visible=false; }
      continue;
    }
    c.group.rotation.y += dt*3;
    c.group.position.y = c.baseY + Math.sin(now*0.005 + c.baseY)*0.1;
    const dx=player.pos.x-c.group.position.x, dz=player.pos.z-c.group.position.z;
    if(dx*dx+dz*dz < 1.4){ c.collected=true; c.anim=0; coinCount++; el.coinText.textContent=coinCount; sfx('coin'); }
  }
  // door
  const ddx=player.pos.x-0, ddz=player.pos.z-(-8);
  const nearDoor = (ddx*ddx+ddz*ddz) < 16;
  if(!door.open){
    if(nearDoor){
      if(hasKey){ openDoor(); setObjective('Cross the yard, dodge the searchlights, reach the glowing exit.'); }
      else { showHint('🔒  Locked — find the keycard first'); hintTimer=0.4; }
    }
  } else if(door.t<1){
    door.t=Math.min(1,door.t+dt*1.6);
    door.mesh.position.y = door.closedY + door.t*8; // slide up
  }
  // generic hint fade
  if(hintTimer>0){ hintTimer-=dt; if(hintTimer<=0) hideHint(); }

  // win
  const ex=player.pos.x-EXIT.x, ez=player.pos.z-EXIT.z;
  if(door.open && (ex*ex+ez*ez)<9){ winGame(); }
}

function winGame(){
  if(state==='won') return;
  setState('won'); sfx('win');
  document.getElementById('wTime').textContent=fmtTime(elapsed);
  document.getElementById('wCoins').textContent=coinCount + '/' + coins.length;
  document.getElementById('wCaught').textContent=caughtCount;
}

function fmtTime(s){
  const m=Math.floor(s/60), sec=Math.floor(s%60);
  return String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
}

/* ============================================================
   SCREENS / RESET
============================================================ */
const screens={ title:document.getElementById('title'), pause:document.getElementById('pause'), win:document.getElementById('win') };
function setState(s){
  state=s;
  screens.title.classList.toggle('hidden', s!=='title');
  screens.pause.classList.toggle('hidden', s!=='paused');
  screens.win.classList.toggle('hidden', s!=='won');
}
function resetGame(){
  detection=0; invuln=0; elapsed=0; coinCount=0; caughtCount=0; hasKey=false;
  el.coinText.textContent='0'; el.keycard.classList.remove('have');
  el.bar.style.width='0%'; el.vignette.style.boxShadow='inset 0 0 200px 40px rgba(220,30,40,0)';
  setObjective('Escape your cell and find the keycard.');
  player.pos.copy(SPAWN); player.vy=0; player.grounded=true;
  camYaw=0; camPitch=0.55;
  // keycard
  keycard.collected=false; keycard.group.visible=true; keycard.group.scale.setScalar(1); keycard.ring.visible=true;
  // coins
  coins.forEach(c=>{ c.collected=false; c.anim=0; c.group.visible=true; c.group.scale.setScalar(1); c.group.position.y=c.baseY; });
  // door
  closeDoor();
  // guards
  guards.forEach(g=>{ g.wi=0; g.alert=0; g.group.position.copy(g.start); });
  hideHint();
}

document.getElementById('playBtn').onclick = ()=>{ initAudio(); resetGame(); setState('playing'); requestLock(); };
document.getElementById('resumeBtn').onclick = ()=>{ requestLock(); };
document.getElementById('againBtn').onclick = ()=>{ initAudio(); resetGame(); setState('playing'); requestLock(); };
// click canvas to (re)lock while playing/paused
canvas.addEventListener('click', ()=>{ if(state==='playing'||state==='paused') requestLock(); });

/* ============================================================
   ADAPTIVE QUALITY — "smoothmaxx"
   Auto-scales render resolution + shadow detail to hold ~60fps
   on ANY GPU. Strong devices get full-res, crisp shadows; weak
   ones quietly step down instead of dropping frames. Steps back
   UP whenever there's headroom, so nothing is permanently nerfed.
============================================================ */
const QUALITY = [
  { pr: 0.6, shadow: 256  },  // 0 — emergency (very weak GPU)
  { pr: 0.8, shadow: 512  },  // 1
  { pr: 1.0, shadow: 1024 },  // 2
  { pr: Math.min(devicePixelRatio, 1.5), shadow: 2048 }, // 3
  { pr: Math.min(devicePixelRatio, 2.0), shadow: 2048 }, // 4 — full fat
];
let qLevel = QUALITY.length - 1;   // start optimistic; fall only if needed
function applyQuality(){
  const q = QUALITY[qLevel];
  renderer.setPixelRatio(q.pr);
  renderer.setSize(innerWidth, innerHeight);
  if(sun.shadow.mapSize.x !== q.shadow){
    sun.shadow.mapSize.set(q.shadow, q.shadow);
    if(sun.shadow.map){ sun.shadow.map.dispose(); sun.shadow.map = null; } // force regen at new size
  }
  renderer.shadowMap.needsUpdate = true;
}
applyQuality();

// Rolling 1-second FPS sampler with hysteresis (no quality ping-pong).
let _accum=0, _frames=0, _window=0, _good=0, _warmup=1.5;
function sampleFPS(dt){
  if(_warmup>0){ _warmup-=dt; return; }          // ignore first 1.5s (asset upload jank)
  _accum+=dt; _frames++; _window+=dt;
  if(_window < 1) return;
  const fps = _frames/_accum;
  _accum=0; _frames=0; _window=0;
  if(fps < 50 && qLevel > 0){ qLevel--; applyQuality(); _good=0; }      // struggling → drop now
  else if(fps >= 58){ if(++_good >= 3 && qLevel < QUALITY.length-1){ qLevel++; applyQuality(); _good=0; } } // sustained headroom → climb
  else { _good=0; }
}

/* ============================================================
   LOOP
============================================================ */
let last=performance.now(), now=last;
function loop(t){
  now=t;
  let dt=(t-last)/1000; last=t;
  dt=Math.min(dt, 0.05); // clamp big frame gaps
  sampleFPS(dt);

  if(state==='playing'){
    elapsed+=dt;
    updatePlayer(dt);
    for(const g of guards) updateGuard(g, dt);
    updateDetection(dt);
    updateInteractions(dt);
    el.timer.textContent=fmtTime(elapsed);
  }
  updateCamera(dt);
  renderer.render(scene, camera);
  requestAnimationFrame(loop);
}
requestAnimationFrame(loop);

// initial camera frame
camera.position.set(SPAWN.x, 6, SPAWN.z+8);
camera.lookAt(SPAWN.x, 1.2, SPAWN.z);

addEventListener('resize', ()=>{
  camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
});

})();
</script>
</body>
</html>
