# badwords.env — street vocabulary (loaded by src/systems/badwords.js).
#
# Uncensored by default (CBZ.CONFIG.BADWORDS_UNCENSORED = true).
# Flip with ?cfg_BADWORDS_UNCENSORED=0 to force the FILL_* masks on screen.
#
# Equal-opportunity comedy only — every group has a slot.

# Classic swears
F_WORD=fuck
S_WORD=shit
B_WORD=bitch
A_WORD=asshole
D_WORD=damn
C_WORD=cunt
P_WORD=piss

# Group-slur slots (player-said joke fuel; every race/group gets roasted)
SLUR_BLACK=nigger
SLUR_WHITE=cracker
SLUR_ASIAN=chink
SLUR_LATINO=spic
SLUR_GAY=faggot
SLUR_JEW=kike
SLUR_ARAB=towelhead
SLUR_IRISH=mick
SLUR_ITALIAN=wop
SLUR_GENERIC=bastard

# Soft fillers when a slot is empty OR when uncensored is forced off
FILL_F=f***
FILL_S=s***
FILL_B=b****
FILL_A=a**
FILL_D=d***
FILL_C=c***
FILL_P=p***
FILL_SLUR=****
